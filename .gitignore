# ─────────────────────────────────────────────────────────────────────────────
# CRITICAL: These files must never be committed to version control
# ─────────────────────────────────────────────────────────────────────────────

# Secrets — NEVER commit
.env
*.env
# All .env variants (e.g. .env.container, .env.migrate_tmp) — keep only the template
.env.*
!.env.example
.env.local
.env.production
secrets/
*.pem
*.key
*.cert

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Anchored to repo root — these are Python packaging artifacts. Unanchored
# "lib/" matched services/dashboard-next/lib/ (the Next.js app core) and silently
# excluded it from the repo. Keep them root-only.
/lib/
/lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
ENV/
env/
*.pyc

# Alembic (keep versions, not generated artifacts)
migrations/__pycache__/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
*.log

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Podman / Docker
.podman/

# Data directories (managed by named volumes — not bind mounts)
data/
volumes/

# Backups (store externally, never in repo)
backups/
*.dump
*.sql.gz
*.bak

# Notebooks (if used for analysis — don't want to leak trade data)
*.ipynb_checkpoints/
.jupyter/

# Books / documents uploaded for RAG (Phase 3)
books/
documents/
uploads/

# Claude Code internal state (conversation logs, task outputs)
.claude/

# Browser automation / Playwright MCP artifacts
.playwright-mcp/

# Stale nested project duplicate (has its own .git) — never track
/MessiahFX-Prod/
