# ─────────────────────────────────────────────────────────────────────────────
# MeznaQuantFX AI — Environment Configuration Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your credentials
#   3. NEVER commit .env to git
#
# TRADING_MODE controls whether real orders are placed:
#   paper = all orders simulated, no real capital at risk
#   live  = real orders sent to exchanges (requires explicit activation)
#
# Start with TRADING_MODE=paper. Do not change to live until paper trading
# has been validated for at minimum 4 weeks.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=mezna
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mezna_trading
DATABASE_URL=postgresql+asyncpg://mezna:change_me_in_production@postgres:5432/mezna_trading

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Trading Mode ─────────────────────────────────────────────────────────────
# WARNING: Do NOT set to 'live' until all paper trading gates are passed
TRADING_MODE=paper

# ── Service Configuration ────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
VERSION=0.1.0

# ── Binance ───────────────────────────────────────────────────────────────────
# Use testnet keys during paper trading
# Testnet: https://testnet.binance.vision/
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
# Instruments to track (comma-separated)
BINANCE_SPOT_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
BINANCE_PERP_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT

# ── Oanda (v20 REST + Streaming API) ─────────────────────────────────────────
# Environment: 'practice' for paper trading, 'live' for real trading
# Practice API: https://api-fxpractice.oanda.com
# Live API:     https://api-fxtrade.oanda.com
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice
# Instruments to track (comma-separated, Oanda format)
OANDA_INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY,EUR_GBP

# ── Anthropic (AI Filter) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Haiku: live signal scoring (800ms budget) + risk narratives
# Sonnet: deep trade analysis (extended thinking) + regime detection + digests
AI_SCORING_MODEL=claude-haiku-4-5
AI_ANALYSIS_MODEL=claude-sonnet-4-5
# Hard timeout on the live signal scoring path (ms). Exceeded = pass-through.
AI_TIMEOUT_MS=800
# Regime detection cache TTL seconds (default 15 min — Sonnet call is expensive)
AI_REGIME_CACHE_TTL_SECONDS=900
# News sentiment background task (fetches crypto/FX headlines every 5 min)
NEWS_FETCH_ENABLED=true
NEWS_FETCH_INTERVAL_SECONDS=300
# Optional: CryptoPanic API key for richer crypto news (falls back to RSS if empty)
CRYPTOPANIC_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# Discord
DISCORD_WEBHOOK_URL=
DISCORD_ENABLED=false

# ── Risk Engine Defaults ──────────────────────────────────────────────────────
# These are defaults only. Override via dashboard for live trading.
# Max risk per trade as percentage of capital (0.01 = 1%)
RISK_MAX_PER_TRADE_PCT=0.01
# Maximum daily drawdown before auto-halt (0.03 = 3%)
RISK_MAX_DAILY_DRAWDOWN_PCT=0.03
# Maximum open positions across all strategies
RISK_MAX_OPEN_POSITIONS=5
# Consecutive losing trades before cooldown trigger
RISK_MAX_CONSECUTIVE_LOSSES=5
# Cooldown duration in minutes after consecutive loss limit
RISK_COOLDOWN_MINUTES=30
# Capital allocated to paper trading (in USD equivalent)
PAPER_CAPITAL_USD=5000

# ── Credential Store Encryption ──────────────────────────────────────────────
# REQUIRED to use the dashboard credential manager (Settings tab).
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store this key in Coolify secrets and your local .env ONLY.
# NEVER commit this key to git. Losing it = losing access to all stored credentials.
CREDENTIAL_ENCRYPTION_KEY=

# ── MT5 Bridge (Windows-native — NOT a container) ─────────────────────────────
# The MT5 bridge runs natively on Windows alongside the MT5 terminal.
# It is started via: services/mt5-bridge/run.bat  (or run.ps1)
#
# MT5_BRIDGE_URL:      How the executor container reaches the bridge.
#                      Podman on Windows: host.containers.internal resolves to the host.
#                      Podman on Linux VPS: set to the Windows VPS IP.
MT5_BRIDGE_URL=http://host.containers.internal:8010
MT5_BRIDGE_API_KEY=                  # Must match BRIDGE_API_KEY in services/mt5-bridge/.env
MT5_SPREAD_BPS=10.0                  # Estimated round-trip spread cost (bps) for MT5 instruments

# ── TradingView Signal Mode ────────────────────────────────────────────────────
# TV_SIGNAL_MODE=true  → bot ONLY trades on TradingView webhook signals (recommended)
# TV_SIGNAL_MODE=false → autonomous strategy loops also run alongside TV signals
TV_SIGNAL_MODE=true

# ── Next.js Dashboard / Terminal auth ─────────────────────────────────────
# The terminal (localhost:3001) uses signed session cookies + a user roster.
#
# SESSION_SECRET — HMAC signing key for session tokens. REQUIRED in production.
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string
#
# DASHBOARD_USERS — JSON array of operators. Roles: admin | operator | viewer
#   (admin/operator can run controls; viewer is read-only). Hash passwords with
#   services/dashboard-next/scripts/hash-password.mjs (scrypt$...). Example:
#   DASHBOARD_USERS='[{"username":"alice","password":"scrypt$..","role":"admin"},{"username":"bob","password":"scrypt$..","role":"viewer"}]'
DASHBOARD_USERS=
#
# Legacy single-password fallback — used ONLY when DASHBOARD_USERS is empty.
# Any username + this password logs in as an admin. Set DASHBOARD_USERS to disable.
DASHBOARD_PASSWORD=change_me

# ── RAG Knowledge System ──────────────────────────────────────────────────────
# OpenAI embeddings for the Qdrant vector store (text-embedding-3-small).
# Used by: services/rag
# Note: ANTHROPIC_API_KEY above also powers RAG synthesis + book analysis.
OPENAI_API_KEY=
QDRANT_URL=http://qdrant:6333          # Internal — do not change for standard Podman Compose

# RAG Synthesis (Claude Haiku — per-query answers, cheap + fast)
SYNTHESIS_MODEL=claude-haiku-4-5
SYNTHESIS_MAX_TOKENS=1024
SYNTHESIS_TIMEOUT_SECONDS=15

# RAG Book Analysis (Claude Sonnet — strategy extraction, once per upload)
# Sonnet reads each book section-by-section and extracts structured risk
# management rules, entry/exit criteria, and trading strategy profiles.
# Increase ANALYSIS_TIMEOUT_SECONDS for very large books (>400 pages).
ANALYSIS_MODEL=claude-sonnet-4-5
ANALYSIS_MAX_TOKENS=4096
ANALYSIS_TIMEOUT_SECONDS=180
ANALYSIS_SECTION_CHARS=12000

# ── Observability ────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana
PROMETHEUS_RETENTION_DAYS=15

# Podman socket path — needed by Promtail to discover container logs.
# Podman rootless on Linux:  /run/user/1000/podman/podman.sock
# Podman rootful on Linux:   /run/podman/podman.sock
# Podman Desktop on Windows: check Podman Desktop settings for socket path
PODMAN_SOCKET_PATH=/run/user/1000/podman/podman.sock

# ── Service URLs (internal — do not change for standard Podman Compose) ───────
GATEWAY_URL=http://gateway:8000
MARKET_DATA_URL=http://market-data:8001
STRATEGY_URL=http://strategy:8002
RISK_URL=http://risk:8003
EXECUTOR_URL=http://executor:8004
AI_FILTER_URL=http://ai-filter:8005
JOURNAL_URL=http://journal:8006
NOTIFICATIONS_URL=http://notifications:8007
BACKTEST_URL=http://backtest:8008
RAG_URL=http://rag:8009
