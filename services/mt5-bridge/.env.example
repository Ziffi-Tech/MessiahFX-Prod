# ─────────────────────────────────────────────────────────────────────────────
# MeznaQuantFX — MT5 Bridge Configuration
#
# This service runs NATIVELY on Windows — it is NOT a container.
#
# SETUP:
#   1. Copy this file:  copy .env.example .env
#   2. Fill in your MT5 account details below
#   3. Start MetaTrader 5 and log in
#   4. Run:  run.bat  (or  run.ps1 in PowerShell)
#
# The executor container reaches this bridge at:
#   http://host.containers.internal:8010   (Podman on Windows)
#   http://<windows-vps-ip>:8010           (Podman on Linux VPS)
# ─────────────────────────────────────────────────────────────────────────────

# ── MT5 Terminal Connection ───────────────────────────────────────────────────
# Your MetaTrader 5 account number (integer — shown in MT5 Navigator panel)
MT5_ACCOUNT=0

# Your MT5 account password
MT5_PASSWORD=

# Broker server name — exactly as shown in MT5 login window
# Examples: ICMarkets-Demo02, Pepperstone-Demo, XM-Demo3
MT5_SERVER=

# Optional: full path to terminal64.exe if auto-detection fails.
# Usually not needed — leave empty for auto-detect.
# Example: C:\Program Files\MetaTrader 5\terminal64.exe
MT5_PATH=

# ── Security ──────────────────────────────────────────────────────────────────
# Bearer token for request authentication.
# REQUIRED for live trading. Leave empty only for local development.
# Must match MT5_BRIDGE_API_KEY in the executor container's .env.
#
# Generate a strong token:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
BRIDGE_API_KEY=

# ── Order Settings ────────────────────────────────────────────────────────────
# Magic number — identifies MeznaQuantFX orders in MT5 history.
# Change only if you have another EA using 234000.
MAGIC_NUMBER=234000

# Maximum slippage in points for market orders (broker default is usually 3-20).
# Higher values improve fill rate but allow more adverse slippage.
DEFAULT_DEVIATION=20

# Hard cap on lot size — prevents grossly oversized orders.
# Set below your broker's max and your own risk comfort level.
MAX_LOT_SIZE=10.0
MIN_LOT_SIZE=0.01

# ── Symbol Mapping ────────────────────────────────────────────────────────────
# Maps internal symbol format (EUR/USD) to exact MT5 broker symbol name (EURUSD).
# MT5 symbol names vary by broker — check your broker's Market Watch window.
#
# Format: internal:mt5_name (comma-separated, no spaces)
# The default covers most major FX pairs + common CFDs on IC Markets / Pepperstone.
# Edit to match YOUR broker's exact symbol names.
#
SYMBOL_MAP=EUR/USD:EURUSD,GBP/USD:GBPUSD,USD/JPY:USDJPY,GBP/JPY:GBPJPY,EUR/JPY:EURJPY,AUD/USD:AUDUSD,USD/CAD:USDCAD,USD/CHF:USDCHF,NZD/USD:NZDUSD,EUR/GBP:EURGBP,XAU/USD:XAUUSD,XAG/USD:XAGUSD,US30:US30,NAS100:NAS100,SPX500:SP500,WTI:USOIL

# ── Service ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8010
LOG_LEVEL=INFO
DEBUG=false
