FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install shared package
COPY shared/ /tmp/shared/
RUN pip install --no-cache-dir /tmp/shared && rm -rf /tmp/shared

# Install alembic + asyncpg
RUN pip install --no-cache-dir alembic>=1.13.0 asyncpg>=0.29.0 sqlalchemy[asyncio]>=2.0

# Copy migration files
COPY migrations/ ./migrations/

RUN groupadd -r appuser && useradd -r -g appuser appuser && \
    chown -R appuser:appuser /app
USER appuser

# Default command runs upgrade head
# Override COMMAND env var to run other alembic commands (current, history, etc.)
CMD ["sh", "-c", "alembic -c migrations/alembic.ini ${COMMAND:-upgrade head}"]
